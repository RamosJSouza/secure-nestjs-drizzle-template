# Application
NODE_ENV=development
APP_NAME=admin-rbac-system

# Server (runtime uses PORT)
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL=false
# Optional: used by Drizzle tooling. If set, overrides DB_* for migrations.
# Example: postgresql://user:password@localhost:5432/admin_limify
DATABASE_URL=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RBAC permission cache TTL in milliseconds (default 5 minutes)
RBAC_CACHE_TTL=300000

# Auth - JWT RS256 (PRIVATE_KEY assina, PUBLIC_KEY verifica)
# Gerar par de chaves:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Para .env: cole o conteúdo PEM em uma única linha, substituindo quebras por \n
# OBRIGATÓRIO em produção.
PRIVATE_KEY=
PUBLIC_KEY=

# CORS (obrigatório em produção: URLs separadas por vírgula)
# Ex: ALLOWED_ORIGINS=https://admin.example.com,https://app.example.com
ALLOWED_ORIGINS=

# Resend (legacy — prefer SMTP / Nodemailer via MailModule)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Frontend base URL for email links (no trailing slash)
APP_URL=http://localhost:3000

# SMTP (production). Development uses Ethereal auto-account.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=NestJS Security Pro

# Opaque token TTLs (seconds)
PASSWORD_RESET_TOKEN_TTL_SECONDS=900
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400

# Grace period after password change (hours)
PASSWORD_CHANGE_GRACE_PERIOD_HOURS=24
FORGOT_PASSWORD_MIN_RESPONSE_MS=250

DISABLE_REDIS=true # Set to true when Redis is not available locally
