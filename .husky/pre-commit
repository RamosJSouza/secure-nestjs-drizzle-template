#!/bin/sh
# pre-commit: bloqueia commit se existirem vulnerabilidades HIGH/CRITICAL no npm audit.
# Nível moderate não bloqueia pois os moderados restantes requerem downgrades de breaking
# change sem exploração real no contexto deste backend:
#   - esbuild <=0.24.2 (GHSA-67mh-4wv8-2f99): afeta apenas o dev server do esbuild;
#     drizzle-kit usa esbuild como bundler — superfície de ataque inexistente.
#   - file-type 13-21.3.1 (GHSA-5v7r-6r5c-r473, GHSA-j47w-4g3g-c36v): loop infinito/
#     ZIP bomb no parser ASF/ZIP; requer endpoint de upload de arquivos — ausente neste backend.
# Para corrigir os moderados sem risco de regressão, aguardar atualização dos mantenedores.
# Para pular em emergência: git commit --no-verify (use apenas em hotfixes críticos).

echo "[pre-commit] Executando npm audit --audit-level=high..."
npm audit --audit-level=high

if [ $? -ne 0 ]; then
  echo ""
  echo "npm audit encontrou vulnerabilidades HIGH ou CRITICAL."
  echo "   Execute: npm audit fix"
  echo "   Para forçar o commit em emergência: git commit --no-verify"
  exit 1
fi

echo "[pre-commit] npm audit: sem vulnerabilidades HIGH+. Commit liberado."
