{
  "name": "secure-nestjs-drizzle-template",
  "version": "1.0.0",
  "description": "Production-grade NestJS + Drizzle ORM template focado em segurança enterprise (SOC 2/GDPR). Inclui JWT RS256 assimétrico com rotação, RBAC DB-driven, audit logging append-only, multi-tenancy via PostgreSQL RLS, risk engine, device fingerprinting e webhooks.",
  "keywords": [
    "nestjs",
    "drizzle",
    "security",
    "soc2",
    "gdpr",
    "lgpd",
    "fintech",
    "healthtech",
    "rbac",
    "audit",
    "multi-tenancy",
    "jwt",
    "typescript",
    "postgresql",
    "risk-engine",
    "argon2",
    "webhooks"
  ],
  "author": {
    "name": "Ramos de Souza Janones",
    "linkedin": "https://www.linkedin.com/in/ramos-souza/",
    "github": "https://github.com/RamosJSouza/",
    "website": "https://ramosdainformatica.com.br/"
  },
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RamosJSouza/secure-nestjs-drizzle-template.git"
  },
  "bugs": {
    "url": "https://github.com/RamosJSouza/secure-nestjs-drizzle-template/issues"
  },
  "homepage": "https://github.com/RamosJSouza/secure-nestjs-drizzle-template#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "drizzle.config.ts",
    ".env.example",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "overrides": {
    "eslint": {
      "ajv": "^6.14.0"
    },
    "schema-utils@3": {
      "ajv": "^6.14.0"
    },
    "@angular-devkit/core": {
      "ajv": "^8.18.0"
    },
    "@eslint/config-array": {
      "minimatch": ">=10.2.3"
    }
  },
  "scripts": {
    "prepare": "husky",
    "dev": "rimraf dist tsconfig.tsbuildinfo && nest start --watch",
    "build": "rimraf dist tsconfig.tsbuildinfo && nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:rbac": "ts-node -r tsconfig-paths/register src/migrations/seeds/run-seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "ci:lint": "eslint \"{src,apps,libs,test}/**/*.ts\" && prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "ci:test": "jest --coverage --forceExit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "audit:fix": "npm audit fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:scan": "docker build -t app-scan:local . && trivy image --severity HIGH,CRITICAL app-scan:local"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "11.1.13",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.13",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mapped-types": "2.1.0",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schedule": "6.1.1",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "17.2.4",
    "drizzle-orm": "^0.44.7",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "nest-resend": "^3.1.0",
    "nestjs-pino": "^4.5.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^5.10.0",
    "reflect-metadata": "0.2.2",
    "resend": "^6.9.2",
    "rimraf": "6.1.2",
    "rxjs": "7.8.2",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.13",
    "@types/bcryptjs": "3.0.0",
    "@types/cron": "2.4.3",
    "@types/eslint": "9.6.1",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/eslint-plugin-prettier": "3.1.3",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.2.3",
    "@types/passport": "1.0.17",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/pg": "^8.18.0",
    "@types/prettier": "3.0.0",
    "@types/rimraf": "4.0.5",
    "@types/supertest": "6.0.3",
    "@types/swagger-ui-express": "4.1.8",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "^9.1.7",
    "jest": "30.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1",
    "supertest": "7.2.2",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1",
      "^@/(.*)$": "<rootDir>/$1",
      "^@auth/(.*)$": "<rootDir>/auth/$1",
      "^@users/(.*)$": "<rootDir>/users/$1",
      "^@tasks/(.*)$": "<rootDir>/tasks/$1",
      "^@config/(.*)$": "<rootDir>/config/$1"
    }
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  }
}
